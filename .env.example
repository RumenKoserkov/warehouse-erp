APP_NAME="Warehouse ERP"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Europe/Sofia

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=warehouse_erp
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_NAME=warehouse_erp_session
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=Lax

TRUSTED_HOSTS=127.0.0.1,localhost,::1

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

SESSION_IDLE_TIMEOUT=1800
SESSION_ABSOLUTE_TIMEOUT=43200
SESSION_RENEWAL_INTERVAL=1800
SESSION_USER_RECHECK_INTERVAL=300